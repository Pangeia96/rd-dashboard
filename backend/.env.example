# ============================================================
# ARQUIVO DE EXEMPLO — RD Station Dashboard
# Copie este arquivo para ".env" e preencha com seus dados reais
# ============================================================

# --- Credenciais da API RD Station (OAuth 2.0) ---
RD_CLIENT_ID=seu_client_id_aqui
RD_CLIENT_SECRET=seu_client_secret_aqui

# URL de redirecionamento após autorização OAuth
RD_REDIRECT_URI=https://seudominio.com/callback

# --- Tokens OAuth (preenchidos automaticamente após autenticação) ---
RD_ACCESS_TOKEN=
RD_REFRESH_TOKEN=

# --- Configurações do servidor backend ---
BACKEND_PORT=8000
SECRET_KEY=gere_uma_string_aleatoria_longa_aqui

# --- Configurações de cache ---
# 3600 = 1 hora | 21600 = 6 horas | 86400 = 24 horas
CACHE_TTL_SECONDS=3600

# --- Credenciais da NuvemShop ---
NUVEMSHOP_USER_ID=seu_user_id_aqui
NUVEMSHOP_ACCESS_TOKEN=seu_access_token_aqui
NUVEMSHOP_API_BASE=https://api.tiendanube.com/v1

# --- Período padrão de análise ---
DEFAULT_DATE_FROM=2025-09-01

# --- Supabase (banco de dados) ---
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_ANON_KEY=sua_anon_key_aqui
SUPABASE_SERVICE_KEY=sua_service_role_key_aqui

# --- Ambiente de execução ---
# "development" ou "production"
ENVIRONMENT=development
